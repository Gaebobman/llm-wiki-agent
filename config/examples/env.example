TELEGRAM_BOT_TOKEN=123456:xxxx
TELEGRAM_ALLOWED_USER_IDS=123456789

OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=http://host.docker.internal:8000/v1

EMBEDDING_API_KEY=sk-...
EMBEDDING_BASE_URL=http://host.docker.internal:8001/v1

LLM_MODEL=qwen3.5-27b
EMBEDDING_MODEL=qwen3-embedding-4b

# Optional semantic planner command.
# The agent sends JSON on stdin and expects strict JSON on stdout.
# If unset, /update still works with a conservative command-context fallback.
# LLM_PLANNER_COMMAND=/data/config/planner-wrapper.sh
LLM_PLANNER_TIMEOUT_SECONDS=30

QMD_MODE=auto
QMD_CONFIG=/data/config/qmd.yaml
QMD_BINARY=qmd
QMD_TIMEOUT_SECONDS=30
# Optional command templates. Supported placeholders:
# {config}, {query}, {mode}, {top_k}, {vault}
# QMD_REFRESH_COMMAND=qmd refresh --config {config}
# QMD_SEARCH_COMMAND=qmd search --config {config} --profile {mode} --json --top-k {top_k} {query}

OPENXML_PARSER_SRC=/home/standard/0_Code/llm-wiki-agent/vendor/openxml-parser/src
EXTRACT_OPENXML_ASSETS=true
